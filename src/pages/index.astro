---
import Layout from '../layouts/Layout.astro';
import Logo from '../components/Logo.astro';

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is Generative Engine Optimisation (GEO)?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "GEO is the practice of optimising your content so it gets cited, referenced, and surfaced by AI-powered search engines — think Google AI Overviews, Perplexity, and ChatGPT. Where traditional SEO gets you onto a results page, GEO gets you into the answer itself."
      }
    },
    {
      "@type": "Question",
      "name": "How is GEO different from SEO?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "SEO is about ranking in Google's traditional blue-link results. GEO is about being the source that AI systems draw from when generating answers. The two complement each other — strong SEO foundations make GEO significantly more effective — but GEO requires its own distinct strategy around content structure, authority signals, and entity clarity."
      }
    },
    {
      "@type": "Question",
      "name": "What is AI visibility and why does it matter?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "AI visibility refers to how prominently your brand, products, or services appear when large language models like ChatGPT or Claude respond to relevant queries. As more people turn to AI assistants instead of search engines, being absent from those responses means missing a growing share of your potential audience — even if your Google rankings are strong."
      }
    },
    {
      "@type": "Question",
      "name": "Do I need GEO if my SEO is already performing well?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Good SEO performance doesn't automatically translate into AI visibility. AI systems draw from a wide range of signals — structured data, brand mentions, content clarity, and third-party citations — that require separate attention. Businesses with strong SEO have a head start, but GEO is a distinct discipline that needs its own strategy."
      }
    },
    {
      "@type": "Question",
      "name": "How long does it take to see results?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "SEO results typically begin showing within 3–6 months, with significant growth compounding over time. GEO and AI visibility can move faster in some areas — particularly Google AI Overviews — though the landscape is evolving quickly. We set realistic timelines based on your current position and provide monthly reporting so you always know where things stand."
      }
    },
    {
      "@type": "Question",
      "name": "How do you measure AI visibility?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "We track AI mentions and citations across key platforms, monitor your presence in Google AI Overviews, and benchmark how often your brand appears in LLM responses to relevant queries. The measurement toolkit for AI visibility is maturing rapidly and we stay at the forefront of what's possible — reporting on metrics that actually reflect commercial impact."
      }
    },
    {
      "@type": "Question",
      "name": "What does a visibility audit cover?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Our visibility audit assesses your current performance across traditional search, AI Overviews, and LLM platforms. We examine technical SEO health, content quality and structure, entity clarity, backlink profile, and AI citation signals. You receive a prioritised action plan that identifies exactly where the biggest gains are and in what order to pursue them."
      }
    }
  ]
};
---

<Layout>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(faqSchema)} />

	<!-- Nav -->
	<nav id="nav" data-theme="dark">
		<div class="container nav-inner">
			<a href="/" class="logo"><Logo /></a>
			<a href="#contact" class="btn-nav">Request an Audit</a>
		</div>
	</nav>

	<!-- Hero — DARK -->
	<section class="hero" id="hero" data-nav-theme="dark">
<div class="container">
			<p class="eyebrow reveal">SEO · GEO · AI Visibility</p>
			<h1 class="reveal reveal-delay-1">Rank everywhere<br />people search.</h1>
			<p class="hero-sub reveal reveal-delay-2">Google. Perplexity. ChatGPT. We get you found wherever people search.</p>
			<div class="hero-cta reveal reveal-delay-3">
				<a href="#contact" class="btn">Request a Visibility Audit</a>
				<a href="#services" class="btn btn-ghost">See What We Do</a>
			</div>
		</div>
	</section>

	<!-- Services — LIGHT -->
	<section class="section light" id="services" data-nav-theme="light">
		<div class="container">
			<div class="section-header reveal">
				<h2>What We Do</h2>
				<p class="section-sub">Search has changed. We keep you ahead of it.</p>
			</div>
			<div class="services-grid">
				<div class="service-box reveal">
					<span class="service-num">01</span>
					<h3>SEO Audit</h3>
					<p>A deep dive into your site's technical, on-page, and off-site health — with a clear action plan focused on the fixes that drive results fastest.</p>
				</div>
				<div class="service-box reveal">
					<span class="service-num">02</span>
					<h3>Technical SEO</h3>
					<p>We audit and fix the under-the-hood issues stopping Google from crawling and ranking your site.</p>
				</div>
				<div class="service-box reveal">
					<span class="service-num">03</span>
					<h3>Content Strategy</h3>
					<p>Keyword research, content planning, and writing that targets the right searches at every stage of the funnel.</p>
				</div>
				<div class="service-box reveal">
					<span class="service-num">04</span>
					<h3>SEO Reporting</h3>
					<p>Clear, jargon-free monthly reports so you always know what's working and what's next.</p>
				</div>
				<div class="service-box reveal service-box--highlight">
					<span class="service-num">05</span>
					<h3>GEO — Generative Engine Optimisation</h3>
					<p>We optimise your content to appear in AI-generated answers on Google AI Overviews, Perplexity, and beyond — the new front page of search.</p>
				</div>
				<div class="service-box reveal service-box--highlight">
					<span class="service-num">06</span>
					<h3>AI Visibility & LLM Presence</h3>
					<p>We get your brand cited, referenced, and recommended by large language models like ChatGPT and Claude — so you're found even when there's no search results page.</p>
				</div>
			</div>
		</div>
	</section>

	<!-- Case Studies — LIGHT -->
	<section class="section light" id="case-studies" data-nav-theme="light">
		<div class="container">
			<div class="section-header reveal">
				<h2>Client Results</h2>
				<p class="section-sub">Real businesses, real growth.</p>
			</div>
			<div class="cases-grid reveal">

				<div class="case-card">
					<div class="case-header">
						<div>
							<p class="case-client">Jolly Good Loans</p>
							<a href="https://jollygoodloans.com" target="_blank" rel="noopener" class="case-url">jollygoodloans.com</a>
						</div>
						<span class="case-tag">Finance</span>
					</div>
					<p class="case-challenge"><strong>Challenge:</strong> Jolly Good Loans had strong products but virtually no organic presence — competitors dominated every high-intent keyword in the UK personal loans market.</p>
					<div class="case-stats">
						<div class="case-stat">
							<span class="case-number">312%</span>
							<span class="case-label">Organic traffic increase</span>
						</div>
						<div class="case-stat">
							<span class="case-number">#1</span>
							<span class="case-label">Ranking for core loan terms</span>
						</div>
						<div class="case-stat">
							<span class="case-number">6mo</span>
							<span class="case-label">Time to results</span>
						</div>
					</div>
					<p class="case-result"><strong>What we did:</strong> Full technical audit, targeted content around loan comparison keywords, and a focused link-building campaign in the personal finance niche. Jolly Good Loans went from page four to page one for their core terms within six months.</p>
				</div>

				<div class="case-card">
					<div class="case-header">
						<div>
							<p class="case-client">Maple & Stone</p>
							<a href="#" class="case-url">mapleandstone.co.uk</a>
						</div>
						<span class="case-tag">Interiors</span>
					</div>
					<p class="case-challenge"><strong>Challenge:</strong> Maple & Stone, a premium interiors brand, was invisible online despite a loyal offline customer base. High-value search terms were dominated by large retail chains.</p>
					<div class="case-stats">
						<div class="case-stat">
							<span class="case-number">5.2x</span>
							<span class="case-label">Organic revenue increase</span>
						</div>
						<div class="case-stat">
							<span class="case-number">+84</span>
							<span class="case-label">First-page keyword rankings</span>
						</div>
						<div class="case-stat">
							<span class="case-number">9mo</span>
							<span class="case-label">Time to results</span>
						</div>
					</div>
					<p class="case-result"><strong>What we did:</strong> We built a content hub around interior design inspiration, combined with a targeted local SEO push and editorial links from home & lifestyle publications. Organic became their top acquisition channel within nine months.</p>
				</div>

				<div class="case-card">
					<div class="case-header">
						<div>
							<p class="case-client">Velo Republic</p>
							<a href="#" class="case-url">velorepublic.com</a>
						</div>
						<span class="case-tag">E-commerce</span>
					</div>
					<p class="case-challenge"><strong>Challenge:</strong> Velo Republic sold premium cycling gear but their site had severe crawl issues and thin product pages that Google refused to rank — despite a strong brand and great reviews.</p>
					<div class="case-stats">
						<div class="case-stat">
							<span class="case-number">228%</span>
							<span class="case-label">Organic traffic increase</span>
						</div>
						<div class="case-stat">
							<span class="case-number">41%</span>
							<span class="case-label">Increase in conversion rate</span>
						</div>
						<div class="case-stat">
							<span class="case-number">4mo</span>
							<span class="case-label">Time to results</span>
						</div>
					</div>
					<p class="case-result"><strong>What we did:</strong> A deep technical SEO overhaul — fixing crawl budget waste, rewriting product and category pages with rich content, and implementing structured data. Rankings and conversions both jumped within a single quarter.</p>
				</div>

			</div>
		</div>
	</section>

	<!-- FAQs — DARK -->
	<section class="section dark" id="faqs" data-nav-theme="dark">
		<div class="container">
			<div class="faq-layout">
				<div class="faq-header reveal">
					<h2>FAQs</h2>
					<p class="section-sub">Everything you need to know about SEO, GEO, and AI visibility.</p>
				</div>
			<div class="faq-list reveal">

				<div class="faq-item">
					<button class="faq-question" aria-expanded="false">
						What is Generative Engine Optimisation (GEO)?
						<span class="faq-icon">+</span>
					</button>
					<div class="faq-answer">
						<p>GEO is the practice of optimising your content so it gets cited, referenced, and surfaced by AI-powered search engines — think Google AI Overviews, Perplexity, and ChatGPT. Where traditional SEO gets you onto a results page, GEO gets you into the answer itself.</p>
					</div>
				</div>

				<div class="faq-item">
					<button class="faq-question" aria-expanded="false">
						How is GEO different from SEO?
						<span class="faq-icon">+</span>
					</button>
					<div class="faq-answer">
						<p>SEO is about ranking in Google's traditional blue-link results. GEO is about being the source that AI systems draw from when generating answers. The two complement each other — strong SEO foundations make GEO significantly more effective — but GEO requires its own distinct strategy around content structure, authority signals, and entity clarity.</p>
					</div>
				</div>

				<div class="faq-item">
					<button class="faq-question" aria-expanded="false">
						What is AI visibility and why does it matter?
						<span class="faq-icon">+</span>
					</button>
					<div class="faq-answer">
						<p>AI visibility refers to how prominently your brand, products, or services appear when large language models like ChatGPT or Claude respond to relevant queries. As more people turn to AI assistants instead of search engines, being absent from those responses means missing a growing share of your potential audience — even if your Google rankings are strong.</p>
					</div>
				</div>

				<div class="faq-item">
					<button class="faq-question" aria-expanded="false">
						Do I need GEO if my SEO is already performing well?
						<span class="faq-icon">+</span>
					</button>
					<div class="faq-answer">
						<p>Yes. Good SEO performance doesn't automatically translate into AI visibility. AI systems draw from a wide range of signals — structured data, brand mentions, content clarity, and third-party citations — that require separate attention. Businesses with strong SEO have a head start, but GEO is a distinct discipline that needs its own strategy.</p>
					</div>
				</div>

				<div class="faq-item">
					<button class="faq-question" aria-expanded="false">
						How long does it take to see results?
						<span class="faq-icon">+</span>
					</button>
					<div class="faq-answer">
						<p>SEO results typically begin showing within 3–6 months, with significant growth compounding over time. GEO and AI visibility can move faster in some areas — particularly Google AI Overviews — though the landscape is evolving quickly. We set realistic timelines based on your current position and provide monthly reporting so you always know where things stand.</p>
					</div>
				</div>

				<div class="faq-item">
					<button class="faq-question" aria-expanded="false">
						How do you measure AI visibility?
						<span class="faq-icon">+</span>
					</button>
					<div class="faq-answer">
						<p>We track AI mentions and citations across key platforms, monitor your presence in Google AI Overviews, and benchmark how often your brand appears in LLM responses to relevant queries. The measurement toolkit for AI visibility is maturing rapidly and we stay at the forefront of what's possible — reporting on metrics that actually reflect commercial impact.</p>
					</div>
				</div>

				<div class="faq-item">
					<button class="faq-question" aria-expanded="false">
						What does a visibility audit cover?
						<span class="faq-icon">+</span>
					</button>
					<div class="faq-answer">
						<p>Our visibility audit assesses your current performance across traditional search, AI Overviews, and LLM platforms. We examine technical SEO health, content quality and structure, entity clarity, backlink profile, and AI citation signals. You receive a prioritised action plan that identifies exactly where the biggest gains are and in what order to pursue them.</p>
					</div>
				</div>

			</div>
			</div>
		</div>
	</section>

	<!-- Contact — LIGHT -->
	<section class="section light" id="contact" data-nav-theme="light">
		<div class="container container-narrow">
			<div class="section-header reveal">
				<h2>Request a Visibility Audit</h2>
				<p class="section-sub">Tell us about your business and we'll show you exactly where you're visible — and where you're missing out — across Google, AI Overviews, Perplexity, and LLMs.</p>
			</div>
			<form class="form reveal">
				<div class="form-row">
					<input type="text" name="name" placeholder="Your name" required />
					<input type="email" name="email" placeholder="Your email" required />
				</div>
				<input type="url" name="website" placeholder="Your website URL" required />
				<textarea name="message" placeholder="Tell us about your business and goals" rows="4"></textarea>
				<button type="submit" class="btn btn-full">Request Your Audit</button>
			</form>
		</div>
	</section>

	<!-- Footer -->
	<footer data-nav-theme="dark">
		<div class="container">
			<div class="footer-top">
				<div class="footer-brand">
					<a href="/" class="logo"><Logo /></a>
					<p class="footer-tagline">SEO · GEO · AI VISIBILITY</p>
				</div>
				<div class="footer-col">
					<h4>Contact</h4>
					<ul>
						<li><a href="mailto:hello@projectone.me">hello@projectone.me</a></li>
						<li><a href="tel:+441234567890">+44 (0)1234 567 890</a></li>
						<li>24 Example Street<br />London, EC1A 1BB<br />United Kingdom</li>
					</ul>
				</div>
				<div class="footer-col">
					<h4>Company</h4>
					<ul>
						<li><a href="/about">About</a></li>
						<li><a href="/cookie-policy">Cookie Policy</a></li>
						<li><a href="/privacy-policy">Privacy Policy</a></li>
					</ul>
				</div>
			</div>
			<div class="footer-bottom">
				<p>&copy; {new Date().getFullYear()} <span style="font-weight:300">project_</span>one. All rights reserved.</p>
			</div>
		</div>
	</footer>

</Layout>

<style>
	/* ── Base ── */
	.container {
		max-width: 1100px;
		margin: 0 auto;
		padding: 0 2rem;
	}

	.container-narrow {
		max-width: 680px;
	}

	/* ── Scroll reveal ── */
	.reveal {
		opacity: 0;
		transform: translateY(28px);
		transition: opacity 0.75s ease, transform 0.75s ease;
	}

	.reveal.visible {
		opacity: 1;
		transform: translateY(0);
	}

	.reveal-delay-1 { transition-delay: 0.1s; }
	.reveal-delay-2 { transition-delay: 0.22s; }
	.reveal-delay-3 { transition-delay: 0.36s; }

	/* ── Nav ── */
	nav {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		z-index: 100;
		padding: 1.25rem 0;
		transition: background 0.5s ease, border-color 0.5s ease;
		border-bottom: 1px solid transparent;
	}

	nav[data-theme="dark"] {
		background: rgba(0, 0, 0, 0.88);
		border-color: #222;
	}

	nav[data-theme="light"] {
		background: rgba(255, 255, 255, 0.9);
		border-color: #e5e7eb;
	}

	.nav-inner {
		display: flex;
		justify-content: space-between;
		align-items: center;
	}

	.logo {
		display: flex;
		align-items: center;
		text-decoration: none;
		transition: color 0.4s ease;
	}

	nav[data-theme="dark"] .logo { color: #fff; }
	nav[data-theme="light"] .logo { color: #000; }

	.btn-nav {
		font-size: 0.85rem;
		font-weight: 600;
		padding: 0.5rem 1.1rem;
		border-radius: 6px;
		text-decoration: none;
		transition: background 0.4s ease, color 0.4s ease, border-color 0.4s ease;
		border: 1px solid transparent;
	}

	nav[data-theme="dark"] .btn-nav {
		background: #fff;
		color: #000;
		border-color: #fff;
	}

	nav[data-theme="light"] .btn-nav {
		background: #000;
		color: #fff;
		border-color: #000;
	}

	/* ── Sections ── */
	.hero,
	.section.dark,
	footer {
		background: #000;
		color: #fff;
	}

	.section.light {
		background: #fff;
		color: #000;
	}

	/* ── Hero ── */
	.hero {
		min-height: 100svh;
		display: flex;
		align-items: center;
		padding: 8rem 0 6rem;
		transition: background 0.5s ease;
	}

	.hero.scrolled {
		background: #fff;
	}

	.hero.scrolled .eyebrow {
		color: #aaa;
	}

	.hero.scrolled h1 {
		color: #000;
	}

	.hero.scrolled .hero-sub {
		color: #666;
	}

	.hero.scrolled .btn {
		background: #000;
		color: #fff;
		border-color: #000;
	}

	.hero.scrolled .btn:hover {
		background: #222;
		border-color: #222;
	}

	.hero.scrolled .btn-ghost {
		background: transparent;
		color: #000;
		border-color: #aaa;
	}

	.hero.scrolled .btn-ghost:hover {
		background: #000;
		color: #fff;
		border-color: #000;
	}

	.eyebrow {
		font-size: 0.78rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.15em;
		color: #b0b0b0;
		margin-bottom: 1.5rem;
		transition: color 0.5s ease;
	}

	.hero h1 {
		font-size: clamp(3.5rem, 8vw, 7rem);
		font-weight: 800;
		line-height: 1.0;
		letter-spacing: -0.04em;
		margin-bottom: 1.5rem;
		color: #fff;
		transition: color 0.5s ease;
	}

	.hero-sub {
		font-size: 1.1rem;
		color: #c8c8c8;
		max-width: 480px;
		margin-bottom: 2.5rem;
		line-height: 1.7;
		transition: color 0.5s ease;
	}

	.hero-cta {
		display: flex;
		gap: 1rem;
		flex-wrap: wrap;
	}

	/* ── Buttons ── */
	.btn {
		display: inline-block;
		background: #fff;
		color: #000;
		padding: 0.85rem 1.75rem;
		border-radius: 6px;
		font-weight: 700;
		font-size: 0.95rem;
		text-decoration: none;
		border: 1px solid #fff;
		cursor: pointer;
		transition: background 0.2s, color 0.2s;
	}

	.btn:hover { background: #e0e0e0; border-color: #e0e0e0; }

	.btn-ghost {
		background: transparent;
		color: #fff;
		border-color: #444;
	}

	.btn-ghost:hover {
		background: #fff;
		color: #000;
		border-color: #fff;
	}

	.btn-full {
		width: 100%;
		text-align: center;
		padding: 1rem;
		font-size: 1rem;
	}

	.section.light .btn-full {
		background: #000;
		color: #fff;
		border-color: #000;
	}

	.section.light .btn-full:hover {
		background: #222;
		border-color: #222;
	}

	/* ── Generic section spacing ── */
	.section {
		padding: 7rem 0;
	}

	.section-header {
		margin-bottom: 4rem;
	}

	.section-header h2 {
		font-size: clamp(2rem, 5vw, 3.5rem);
		font-weight: 800;
		letter-spacing: -0.03em;
		line-height: 1.1;
		margin-bottom: 0.75rem;
	}

	.section-sub {
		font-size: 1rem;
		color: #c8c8c8;
	}

	.section.light .section-sub { color: #666; }

	/* ── Services ── */
	.services-grid {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 1.5rem;
	}

	.services-grid .service-box:nth-child(n+5) {
		grid-column: span 2;
	}

	.service-box {
		border: 1px solid #e5e7eb;
		border-radius: 16px;
		padding: 2rem;
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.service-num {
		font-size: 0.75rem;
		font-weight: 600;
		letter-spacing: 0.08em;
		color: #aaa;
	}

	.service-box h3 {
		font-size: 1.1rem;
		font-weight: 700;
		letter-spacing: -0.01em;
		color: #000;
		margin: 0;
	}

	.service-box p {
		font-size: 0.9rem;
		color: #666;
		line-height: 1.7;
		margin: 0;
	}

	.service-box--highlight {
		background: #000;
		border-color: #000;
	}

	.service-box--highlight .service-num { color: #b0b0b0; }
	.service-box--highlight h3 { color: #fff; }
	.service-box--highlight p  { color: #c8c8c8; }

	/* ── Why sub ── */
	.why-sub {
		margin-top: 3rem;
		font-size: 1rem;
		color: #c8c8c8;
		line-height: 1.8;
		max-width: 720px;
		border-left: 2px solid #444;
		padding-left: 1.5rem;
