<style>
	/* ── Base ── */
	.container {
		max-width: 1100px;
		margin: 0 auto;
		padding: 0 2rem;
	}

	.container-narrow {
		max-width: 680px;
	}

	/* ── Scroll reveal ── */
	.reveal {
		opacity: 0;
		transform: translateY(28px);
		transition: opacity 0.75s ease, transform 0.75s ease;
	}

	.reveal.visible {
		opacity: 1;
		transform: translateY(0);
	}

	.reveal-delay-1 { transition-delay: 0.1s; }
	.reveal-delay-2 { transition-delay: 0.22s; }
	.reveal-delay-3 { transition-delay: 0.36s; }

	/* ── Nav ── */
	nav {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		z-index: 100;
		padding: 1.25rem 0;
		transition: background 0.5s ease, border-color 0.5s ease;
		border-bottom: 1px solid transparent;
	}

	nav[data-theme="dark"] {
		background: rgba(0, 0, 0, 0.88);
		border-color: #222;
	}

	nav[data-theme="light"] {
		background: rgba(255, 255, 255, 0.9);
		border-color: #e5e7eb;
	}

	.nav-inner {
		display: flex;
		justify-content: space-between;
		align-items: center;
	}

	.logo {
		font-weight: 800;
		font-size: 1.1rem;
		letter-spacing: -0.02em;
		transition: color 0.4s ease;
	}

	nav[data-theme="dark"] .logo { color: #fff; }
	nav[data-theme="light"] .logo { color: #000; }

	.btn-nav {
		font-size: 0.85rem;
		font-weight: 600;
		padding: 0.5rem 1.1rem;
		border-radius: 6px;
		text-decoration: none;
		transition: background 0.4s ease, color 0.4s ease, border-color 0.4s ease;
		border: 1px solid transparent;
	}

	nav[data-theme="dark"] .btn-nav {
		background: #fff;
		color: #000;
		border-color: #fff;
	}

	nav[data-theme="light"] .btn-nav {
		background: #000;
		color: #fff;
		border-color: #000;
	}

	/* ── Sections ── */
	.hero,
	.section.dark,
	footer {
		background: #000;
		color: #fff;
	}

	.section.light {
		background: #fff;
		color: #000;
	}

	/* ── Hero ── */
	.hero {
		padding: 14rem 0 9rem;
		transition: background 0.5s ease;
	}

	.hero.scrolled {
		background: #fff;
	}

	.hero.scrolled .eyebrow {
		color: #aaa;
	}

	.hero.scrolled h1 {
		color: #000;
	}

	.hero.scrolled .hero-sub {
		color: #666;
	}

	.hero.scrolled .btn {
		background: #000;
		color: #fff;
		border-color: #000;
	}

	.hero.scrolled .btn:hover {
		background: #222;
		border-color: #222;
	}

	.hero.scrolled .btn-ghost {
		background: transparent;
		color: #000;
		border-color: #aaa;
	}

	.hero.scrolled .btn-ghost:hover {
		background: #000;
		color: #fff;
		border-color: #000;
	}

	.eyebrow {
		font-size: 0.78rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.15em;
		color: #b0b0b0;
		margin-bottom: 1.5rem;
		transition: color 0.5s ease;
	}

	.hero h1 {
		font-size: clamp(3.5rem, 8vw, 7rem);
		font-weight: 800;
		line-height: 1.0;
		letter-spacing: -0.04em;
		margin-bottom: 1.5rem;
		color: #fff;
		transition: color 0.5s ease;
	}

	.hero-sub {
		font-size: 1.1rem;
		color: #c8c8c8;
		max-width: 480px;
		margin-bottom: 2.5rem;
		line-height: 1.7;
		transition: color 0.5s ease;
	}

	.hero-cta {
		display: flex;
		gap: 1rem;
		flex-wrap: wrap;
	}

	/* ── Buttons ── */
	.btn {
		display: inline-block;
		background: #fff;
		color: #000;
		padding: 0.85rem 1.75rem;
		border-radius: 6px;
		font-weight: 700;
		font-size: 0.95rem;
		text-decoration: none;
		border: 1px solid #fff;
		cursor: pointer;
		transition: background 0.2s, color 0.2s;
	}

	.btn:hover { background: #e0e0e0; border-color: #e0e0e0; }

	.btn-ghost {
		background: transparent;
		color: #fff;
		border-color: #444;
	}

	.btn-ghost:hover {
		background: #fff;
		color: #000;
		border-color: #fff;
	}

	.btn-full {
		width: 100%;
		text-align: center;
		padding: 1rem;
		font-size: 1rem;
	}

	.section.light .btn-full {
		background: #000;
		color: #fff;
		border-color: #000;
	}

	.section.light .btn-full:hover {
		background: #222;
		border-color: #222;
	}

	/* ── Generic section spacing ── */
	.section {
		padding: 7rem 0;
	}

	.section-header {
		margin-bottom: 4rem;
	}

	.section-header h2 {
		font-size: clamp(2rem, 5vw, 3.5rem);
		font-weight: 800;
		letter-spacing: -0.03em;
		line-height: 1.1;
		margin-bottom: 0.75rem;
	}

	.section-sub {
		font-size: 1rem;
		color: #c8c8c8;
	}

	.section.light .section-sub { color: #666; }

	/* ── Services ── */
	.services-grid {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 1.5rem;
	}

	.services-grid .service-box:nth-child(n+5) {
		grid-column: span 2;
	}

	.service-box {
		border: 1px solid #e5e7eb;
		border-radius: 16px;
		padding: 2rem;
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.service-num {
		font-size: 0.75rem;
		font-weight: 600;
		letter-spacing: 0.08em;
		color: #aaa;
	}

	.service-box h3 {
		font-size: 1.1rem;
		font-weight: 700;
		letter-spacing: -0.01em;
		color: #000;
		margin: 0;
	}

	.service-box p {
		font-size: 0.9rem;
		color: #666;
		line-height: 1.7;
		margin: 0;
	}

	.service-box--highlight {
		background: #000;
		border-color: #000;
	}

	.service-box--highlight .service-num { color: #b0b0b0; }
	.service-box--highlight h3 { color: #fff; }
	.service-box--highlight p  { color: #c8c8c8; }

	/* ── Why sub ── */
	.why-sub {
		margin-top: 3rem;
		font-size: 1rem;
		color: #c8c8c8;
		line-height: 1.8;
		max-width: 720px;
		border-left: 2px solid #444;
		padding-left: 1.5rem;
	}

	/* ── Stats ── */
	.stats {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		border: 1px solid #222;
		border-radius: 16px;
		overflow: hidden;
	}

	.stat {
		padding: 3rem 2rem;
		border-right: 1px solid #222;
	}

	.stat:last-child { border-right: none; }

